# August 3.5 — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# All variables are prefixed with VITE_ or used via vite.config.ts define block.

# === Required: Core AI Providers ===
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# === Optional: Additional AI Providers ===
GROQ_NEW_API_KEY=your_groq_new_api_key_here
GROQ_ALT2_API_KEY=your_groq_alt2_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROK_API_KEY=your_grok_api_key_here

# === Optional: Overrides ===
# API_KEY is used as a fallback for GEMINI_API_KEY in some accuracy services
# API_KEY=your_fallback_api_key_here
